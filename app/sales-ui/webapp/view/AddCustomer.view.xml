<mvc:View
    controllerName="salesmanagement.salesui.controller.AddCustomer"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout">

<Page
    title="Add Customer"
    showNavButton="true"
    navButtonPress=".onBack"
    class="formPage">

<content>

<VBox class="formPageWrap" alignItems="Center">

    <VBox class="formCard">

        <!-- Card header -->
        <HBox alignItems="Center" class="formCardHeader">
            <core:Icon src="sap-icon://customer" class="formCardHeaderIcon"/>
            <VBox>
                <Title text="Customer Details" level="H3" class="formCardTitle"/>
                <Text text="Add a new customer to your database" class="formCardSubText"/>
            </VBox>
        </HBox>

        <!-- Form fields -->
        <layout:Grid
            defaultSpan="XL6 L6 M12 S12"
            class="formGrid">

            <VBox class="formFieldGroup">
                <Label text="Customer Name" labelFor="customerName" required="true" class="formLabel"/>
                <Input
                    id="customerName"
                    placeholder="e.g. Aman Kumar"
                    class="formInput"/>
            </VBox>

            <VBox class="formFieldGroup">
                <Label text="Phone Number" labelFor="phone" required="true" class="formLabel"/>
                <Input
                    id="phone"
                    type="Tel"
                    placeholder="e.g. +91 98765 43210"
                    class="formInput"/>
            </VBox>

            <VBox class="formFieldGroup">
                <Label text="Email Address" labelFor="email" class="formLabel"/>
                <Input
                    id="email"
                    type="Email"
                    placeholder="e.g. aman.kumar@email.com"
                    class="formInput"/>
            </VBox>

            <VBox class="formFieldGroup">
                <Label text="Address" labelFor="address" class="formLabel"/>
                <Input
                    id="address"
                    placeholder="Street, City, State"
                    class="formInput"/>
            </VBox>

        </layout:Grid>

        <!-- Actions -->
        <HBox
            justifyContent="End"
            alignItems="Center"
            class="formActionsRow">

            <Button
                text="Cancel"
                press=".onBack"
                class="formCancelBtn"/>

            <Button
                text="Save Customer"
                icon="sap-icon://save"
                type="Emphasized"
                press=".onSave"
                class="formSaveBtn sapUiTinyMarginBegin"/>

        </HBox>

    </VBox>

</VBox>

</content>

</Page>

</mvc:View>